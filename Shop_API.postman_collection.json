    "description": "Test collection cho Shop Order Management — Spring Boot Buổi 8.\n\n## Thứ tự chạy\n1. Customers → tạo khách hàng\n2. Products → tạo sản phẩm\n3. Orders → tạo và quản lý đơn hàng\n\n## Biến môi trường\nSử dụng variable {{base_url}} = http://localhost:8080/api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api", "type": "string" }
  ],
  "item": [
    {
      "name": "✅ CUSTOMERS",
      "item": [
        {
          "name": "✅ 1. Tạo khách hàng hợp lệ",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/customers", "host": ["{{base_url}}"], "path": ["customers"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Nguyễn Văn A\",\n  \"phone\": \"0912345678\",\n  \"email\": \"a@example.com\",\n  \"address\": \"Quận 1, TP.HCM\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Có id', () => pm.expect(pm.response.json().id).to.be.a('number'));",
                  "pm.test('fullName đúng', () => pm.expect(pm.response.json().fullName).to.equal('Nguyễn Văn A'));",
                  "pm.collectionVariables.set('customer_id', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "✅ 2. Tạo khách hàng thứ 2",
